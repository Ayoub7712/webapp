{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.+\\.(?:js|css|html|ico|png|jpg|jpeg|svg|gif|woff2?|ttf|eot|json))",
      "dest": "frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/login.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
